# Absolute path to the Navidrome media folder (same on host and container)
NAVIDROME_MEDIA_DIR=/path/to/your/music

# API
API_PORT=8000

# Web — must be reachable from the browser (not docker-internal hostname)
WEB_PORT=3000
NUXT_PUBLIC_API_BASE=http://localhost:8000

# CORS: comma-separated list of allowed origins for the API
CORS_ORIGINS=http://localhost:3000